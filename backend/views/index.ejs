<% if (user) { %>
    <form action="/tweets" method="POST" enctype="multipart/form-data" class="tweetForm">
        <textarea name="content" placeholder="What's happening?" class="textarea" required maxlength="280"></textarea>
        <div class="tweetFormActions">
            <input type="file" name="media" class="fileInput">
            <button type="submit" class="tweetButton">Tweet</button>
        </div>
    </form>

    <div class="tweetList">
        <% if (tweets && tweets.length > 0) { %>
            <% tweets.forEach(tweet => { %>
                <div class="tweetCard">
                    <div class="avatar"></div>
                    <div class="tweetMain">
                        <div class="tweetHeader">
                            <span class="displayName"><%= tweet.display_name %></span>
                            <a href="/u/<%= tweet.username %>" class="username">@<%= tweet.username %></a>
                            <span class="time">· <%= new Date(tweet.created_at).toLocaleDateString() %></span>
                        </div>
                        <a href="/tweet/<%= tweet.id %>" class="tweetContent" style="display: block; color: inherit; text-decoration: none;">
                            <%= tweet.content %>
                        </a>
                        <% if (tweet.media_url) { %>
                            <div class="tweetMedia">
                                <img src="/uploads/<%= tweet.media_url %>" class="mediaImage">
                            </div>
                        <% } %>
                        <div class="tweetEngagement">
                            <div class="engagementItem">
                                <form action="/tweets/<%= tweet.id %>/like" method="POST">
                                    <button type="submit" class="engagementButton <%= tweet.has_liked ? 'liked' : '' %>">
                                        Like <%= tweet.like_count %>
                                    </button>
                                </form>
                            </div>
                            <div class="engagementItem">
                                <form action="/tweets/<%= tweet.id %>/retweet" method="POST">
                                    <button type="submit" class="engagementButton <%= tweet.has_retweeted ? 'retweeted' : '' %>">
                                        Retweet <%= tweet.retweet_count %>
                                    </button>
                                </form>
                            </div>
                            <div class="engagementItem">
                                <a href="/tweet/<%= tweet.id %>" class="engagementButton">Reply <%= tweet.reply_count %></a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="noTweets">No tweets to show.</p>
        <% } %>
    </div>
<% } else { %>
    <div class="hero">
        <div class="twitHeader">
            <h1>Welcome to Twit</h1>
            <p>The massively scalable, microblogging platform.</p>
        </div>

        <div class="authBox">
            <a href="/signup" class="signupButton">Create Account</a>
            <a href="/login" class="loginButton">Sign In</a>
        </div>
    </div>
<% } %>
