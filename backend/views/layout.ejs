<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> / Twit</title>
    <!-- Self-hosted Bootstrap -->
    <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        :root {
            --twitter-blue: #1d9bf0;
            --twitter-blue-hover: #1a8cd8;
            --bg-dark: #000000;
            --border-color: #2f3336;
        }
        body {
            background-color: var(--bg-dark);
            color: #eff3f4;
        }
        .navbar {
            border-bottom: 1px solid var(--border-color);
            background-color: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(12px);
        }
        .btn-primary {
            background-color: var(--twitter-blue);
            border-color: var(--twitter-blue);
            border-radius: 9999px;
            font-weight: 700;
        }
        .btn-primary:hover {
            background-color: var(--twitter-blue-hover);
            border-color: var(--twitter-blue-hover);
        }
        .card {
            background-color: transparent;
            border-color: var(--border-color);
            border-radius: 16px;
        }
        .list-group-item {
            background-color: transparent;
            border-color: var(--border-color);
            color: inherit;
        }
        .tweet-card {
            border-bottom: 1px solid var(--border-color);
            padding: 12px 16px;
            transition: background-color 0.2s;
        }
        .tweet-card:hover {
            background-color: rgba(255, 255, 255, 0.03);
        }
        .sidebar-item {
            border-radius: 16px;
            background-color: #16181c;
            padding: 16px;
            margin-bottom: 16px;
        }
        .nav-link {
            color: #eff3f4;
            font-size: 20px;
            padding: 12px;
            border-radius: 9999px;
        }
        .nav-link:hover {
            background-color: rgba(239, 243, 244, 0.1);
            color: #eff3f4;
        }
        .logo-text {
            color: var(--twitter-blue);
            font-weight: 800;
            font-size: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row">
            <!-- Left Sidebar Navigation -->
            <div class="col-md-3 d-none d-md-block sticky-top vh-100 py-3">
                <a href="/" class="d-block mb-4 ps-3 logo-text text-decoration-none">Twit</a>
                <nav class="nav flex-column">
                    <a class="nav-link" href="/">Home</a>
                    <% if (user) { %>
                        <a class="nav-link" href="/notifications">Notifications <% if (notificationsCount > 0) { %><span class="badge bg-primary rounded-pill"><%= notificationsCount %></span><% } %></a>
                        <a class="nav-link" href="/messages">Messages</a>
                        <a class="nav-link" href="/bookmarks">Bookmarks</a>
                        <a class="nav-link" href="/lists">Lists</a>
                        <a class="nav-link" href="/u/<%= user.username %>">Profile</a>
                        <% if (user.is_admin) { %>
                            <a class="nav-link text-info" href="/admin">Admin</a>
                        <% } %>
                        <div class="mt-4">
                            <form action="/auth/logout" method="POST">
                                <button type="submit" class="btn btn-outline-light rounded-pill w-100">Log Out</button>
                            </form>
                        </div>
                    <% } else { %>
                        <a class="nav-link" href="/login">Login</a>
                        <a class="nav-link" href="/signup">Sign Up</a>
                    <% } %>
                </nav>
            </div>

            <!-- Main Content Area -->
            <div class="col-md-6 border-start border-end border-secondary min-vh-100 p-0">
                <header class="sticky-top bg-black bg-opacity-75 p-3 border-bottom border-secondary" style="backdrop-filter: blur(12px); z-index: 1000;">
                    <h5 class="mb-0 fw-bold"><%= title %></h5>
                </header>
                <%- body %>
            </div>

            <!-- Right Sidebar -->
            <div class="col-md-3 d-none d-md-block py-3">
                <div class="mb-4">
                    <form action="/search" method="GET">
                        <input type="text" name="q" placeholder="Search Twit" class="form-control rounded-pill bg-dark border-secondary text-white py-2 px-4">
                    </form>
                </div>

                <div class="sidebar-item">
                    <h5 class="fw-bold mb-3">What's happening</h5>
                    <% if (trending && trending.length > 0) { %>
                        <% trending.forEach(trend => { %>
                            <a href="/search?q=<%= trend.tag %>" class="d-block text-decoration-none py-2 border-bottom border-secondary last-child-border-0">
                                <div class="text-secondary small">Trending</div>
                                <div class="fw-bold text-white">#<%= trend.tag %></div>
                                <div class="text-secondary small"><%= trend.tweet_count %> Tweets</div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p class="text-secondary mb-0">No trends yet.</p>
                    <% } %>
                </div>

                <div class="px-3 text-secondary small">
                    &copy; 2026 Twit. Self-Hosted. JS-Free.
                </div>
            </div>
        </div>
    </div>
</body>
</html>
