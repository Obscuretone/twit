<div class="p-5">
    <div class="row justify-content-center mt-5">
        <div class="col-md-10">
            <h1 class="display-5 fw-bold mb-4">Sign in to Twit</h1>
            
            <% if (error) { %>
                <div class="alert alert-danger" role="alert">
                    <%= error %>
                </div>
            <% } %>

            <form action="/auth/login" method="POST" class="d-grid gap-3">
                <div class="form-floating mb-1">
                    <input type="text" name="identifier" class="form-control bg-black border-secondary text-white" id="floatingInput" placeholder="Username or Email" required>
                    <label for="floatingInput" class="text-secondary">Username or Email</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="password" name="password" class="form-control bg-black border-secondary text-white" id="floatingPassword" placeholder="Password" required>
                    <label for="floatingPassword" class="text-secondary">Password</label>
                </div>
                
                <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3">Log In</button>
                
                <p class="text-center mt-4 text-secondary">
                    Don't have an account? <a href="/signup" class="text-primary text-decoration-none">Sign up</a>
                </p>
            </form>
        </div>
    </div>
</div>
